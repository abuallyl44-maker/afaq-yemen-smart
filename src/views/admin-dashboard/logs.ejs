<div>
    <div class="card">
        <div class="card-header">
            <h3>📜 سجل حركات المشرفين</h3>
            <div>
                <button class="btn btn-primary btn-sm" onclick="refreshLogs()">تحديث</button>
                <button class="btn btn-secondary btn-sm" onclick="exportLogs()">تصدير CSV</button>
            </div>
        </div>
        <div style="padding: 20px;">
            <!-- فلاتر -->
            <div style="display: flex; gap: 10px; margin-bottom: 20px; flex-wrap: wrap;">
                <select id="actionFilter" class="form-control" style="width: 150px;">
                    <option value="">كل الإجراءات</option>
                    <option value="confirm_payment">تأكيد دفع</option>
                    <option value="reject_payment">رفض دفع</option>
                    <option value="suspend_user">تعليق مستخدم</option>
                    <option value="activate_user">تفعيل مستخدم</option>
                    <option value="update_settings">تحديث إعدادات</option>
                </select>
                <input type="date" id="dateFrom" class="form-control" style="width: 150px;" placeholder="من تاريخ">
                <input type="date" id="dateTo" class="form-control" style="width: 150px;" placeholder="إلى تاريخ">
                <button class="btn btn-primary btn-sm" onclick="applyFilters()">تطبيق</button>
                <button class="btn btn-secondary btn-sm" onclick="resetFilters()">إعادة تعيين</button>
            </div>

            <!-- الجدول -->
            <div style="overflow-x: auto;">
                <table class="table" id="logsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>المشرف</th>
                            <th>الإجراء</th>
                            <th>المستهدف</th>
                            <th>التفاصيل</th>
                            <th>عنوان IP</th>
                            <th>التاريخ</th>
                         </tr>
                    </thead>
                    <tbody>
                        <% if (logs && logs.length > 0) { %>
                            <% logs.forEach(log => { %>
                                <tr>
                                    <td><%= log.log_id %></td>
                                    <td><%= log.admin?.email || '-' %></td>
                                    <td>
                                        <span class="badge <%= 
                                            log.action === 'confirm_payment' ? 'badge-success' : 
                                            (log.action === 'reject_payment' ? 'badge-danger' : 
                                            (log.action === 'suspend_user' ? 'badge-warning' : 'badge-info')) %>">
                                            <%= log.action === 'confirm_payment' ? 'تأكيد دفع' :
                                               (log.action === 'reject_payment' ? 'رفض دفع' :
                                               (log.action === 'suspend_user' ? 'تعليق مستخدم' :
                                               (log.action === 'activate_user' ? 'تفعيل مستخدم' :
                                               (log.action === 'update_settings' ? 'تحديث إعدادات' : log.action)))) %>
                                        </span>
                                    </td>
                                    <td><%= log.target_type %> #<%= log.target_id || '-' %></td>
                                    <td><%= log.details ? (typeof log.details === 'object' ? JSON.stringify(log.details).substring(0, 100) : log.details.substring(0, 100)) : '-' %>...</td>
                                    <td><%= log.ip_address || '-' %></td>
                                    <td><%= new Date(log.created_at).toLocaleString('ar') %></td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="7" style="text-align: center;">لا توجد سجلات</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

            <!-- الترقيم -->
            <% if (totalPages > 1) { %>
            <div style="display: flex; justify-content: center; gap: 10px; margin-top: 20px;">
                <button class="btn btn-sm btn-secondary" onclick="goToPage(<%= currentPage - 1 %>)" <%= currentPage === 1 ? 'disabled' : '' %>>السابق</button>
                <span>الصفحة <%= currentPage %> من <%= totalPages %></span>
                <button class="btn btn-sm btn-secondary" onclick="goToPage(<%= currentPage + 1 %>)" <%= currentPage === totalPages ? 'disabled' : '' %>>التالي</button>
            </div>
            <% } %>
        </div>
    </div>
</div>

<script>
    let currentFilters = { action: '', dateFrom: '', dateTo: '', page: 1 };
    
    function applyFilters() {
        currentFilters.action = document.getElementById('actionFilter').value;
        currentFilters.dateFrom = document.getElementById('dateFrom').value;
        currentFilters.dateTo = document.getElementById('dateTo').value;
        currentFilters.page = 1;
        loadLogs();
    }
    
    function resetFilters() {
        document.getElementById('actionFilter').value = '';
        document.getElementById('dateFrom').value = '';
        document.getElementById('dateTo').value = '';
        currentFilters = { action: '', dateFrom: '', dateTo: '', page: 1 };
        loadLogs();
    }
    
    function goToPage(page) {
        if (page < 1) return;
        currentFilters.page = page;
        loadLogs();
    }
    
    async function loadLogs() {
        const params = new URLSearchParams();
        if (currentFilters.action) params.append('action', currentFilters.action);
        if (currentFilters.dateFrom) params.append('dateFrom', currentFilters.dateFrom);
        if (currentFilters.dateTo) params.append('dateTo', currentFilters.dateTo);
        params.append('page', currentFilters.page);
        
        const data = await apiFetch(`/api/admin/logs?${params.toString()}`);
        // تحديث الجدول (يمكن إعادة تحميل الصفحة أو تحديث DOM)
        location.reload();
    }
    
    function refreshLogs() {
        loadLogs();
    }
    
    async function exportLogs() {
        const params = new URLSearchParams();
        if (currentFilters.action) params.append('action', currentFilters.action);
        if (currentFilters.dateFrom) params.append('dateFrom', currentFilters.dateFrom);
        if (currentFilters.dateTo) params.append('dateTo', currentFilters.dateTo);
        
        window.location.href = `/api/admin/logs/export?${params.toString()}`;
    }
</script>