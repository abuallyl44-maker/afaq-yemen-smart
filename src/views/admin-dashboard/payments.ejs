<div>
    <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px;">
        <div class="stat-card">
            <div class="stat-info">
                <h3>الطلبات المنتظرة</h3>
                <div class="number" id="pendingCount"><%= pendingPayments?.length || 0 %></div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>الإيرادات (هذا الشهر)</h3>
                <div class="number"><%= monthlyRevenue || 0 %> ريال</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>الإيرادات الإجمالية</h3>
                <div class="number"><%= totalRevenue || 0 %> ريال</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>الاشتراكات النشطة</h3>
                <div class="number"><%= activeSubscriptions || 0 %></div>
            </div>
        </div>
    </div>

    <!-- طلبات الدفع المنتظرة -->
    <div class="card">
        <div class="card-header">
            <h3>⏳ طلبات الدفع المنتظرة</h3>
            <button class="btn btn-primary btn-sm" onclick="refreshPending()">تحديث</button>
        </div>
        <div style="overflow-x: auto;">
            <table class="table" id="pendingTable">
                <thead>
                    <tr>
                        <th>#</th><th>المستخدم</th><th>المبلغ</th><th>الشركة</th><th>رقم الحوالة</th><th>اسم المرسل</th><th>التاريخ</th><th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (pendingPayments && pendingPayments.length > 0) { %>
                        <% pendingPayments.forEach(payment => { %>
                            <tr>
                                <td><%= payment.payment_id %></td>
                                <td><%= payment.user?.email || '-' %></td>
                                <td><%= payment.amount %> ريال</td>
                                <td><%= payment.company %></td>
                                <td><%= payment.transfer_number %></td>
                                <td><%= payment.sender_name %></td>
                                <td><%= new Date(payment.requested_at).toLocaleDateString('ar') %></td>
                                <td>
                                    <button class="btn btn-success btn-sm" onclick="confirmPaymentModal(<%= payment.payment_id %>, '<%= payment.user?.email %>', <%= payment.amount %>)">تأكيد</button>
                                    <button class="btn btn-danger btn-sm" onclick="rejectPaymentModal(<%= payment.payment_id %>, '<%= payment.user?.email %>')">رفض</button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="8" style="text-align: center;">لا توجد طلبات منتظرة</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- الاشتراكات النشطة -->
    <div class="card">
        <div class="card-header">
            <h3>✅ الاشتراكات النشطة</h3>
            <a href="/admin/plans" class="btn btn-primary btn-sm">إدارة الخطط</a>
        </div>
        <div style="overflow-x: auto;">
            <table class="table">
                <thead>
                    <tr><th>المستخدم</th><th>الخطة</th><th>تاريخ البدء</th><th>تاريخ الانتهاء</th><th>الحالة</th></tr>
                </thead>
                <tbody>
                    <% if (activeSubscriptionsList && activeSubscriptionsList.length > 0) { %>
                        <% activeSubscriptionsList.forEach(sub => { %>
                            <tr>
                                <td><%= sub.user?.email || '-' %></td>
                                <td><%= sub.plan?.name || '-' %></td>
                                <td><%= new Date(sub.start_date).toLocaleDateString('ar') %></td>
                                <td><%= sub.end_date ? new Date(sub.end_date).toLocaleDateString('ar') : 'غير محدود' %></td>
                                <td><span class="badge badge-success">نشط</span></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="5" style="text-align: center;">لا توجد اشتراكات نشطة</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- طلبات الدفع المكتملة -->
    <div class="card">
        <div class="card-header">
            <h3>✅ طلبات الدفع المكتملة</h3>
        </div>
        <div style="overflow-x: auto;">
            <table class="table">
                <thead>
                    <tr><th>#</th><th>المستخدم</th><th>المبلغ</th><th>التاريخ</th><th>الحالة</th></tr>
                </thead>
                <tbody>
                    <% if (confirmedPayments && confirmedPayments.length > 0) { %>
                        <% confirmedPayments.forEach(payment => { %>
                            <tr>
                                <td><%= payment.payment_id %></td>
                                <td><%= payment.user?.email || '-' %></td>
                                <td><%= payment.amount %> ريال</td>
                                <td><%= new Date(payment.confirmed_at).toLocaleDateString('ar') %></td>
                                <td><span class="badge badge-success">مؤكد</span></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="5" style="text-align: center;">لا توجد طلبات مكتملة</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal تأكيد الدفع -->
<div id="confirmModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div style="background: white; padding: 25px; border-radius: 10px; max-width: 400px; width: 90%;">
        <h3>تأكيد الدفع</h3>
        <p id="confirmInfo"></p>
        <div class="form-group">
            <label>معرف الخطة (plan_id):</label>
            <input type="number" id="planId" class="form-control" required>
        </div>
        <div class="form-group">
            <label>ملاحظات:</label>
            <textarea id="adminNotes" class="form-control" rows="2"></textarea>
        </div>
        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button class="btn btn-secondary" onclick="closeModal()">إلغاء</button>
            <button class="btn btn-success" id="confirmBtn">تأكيد</button>
        </div>
    </div>
</div>

<!-- Modal رفض الدفع -->
<div id="rejectModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div style="background: white; padding: 25px; border-radius: 10px; max-width: 400px; width: 90%;">
        <h3>رفض الدفع</h3>
        <p id="rejectInfo"></p>
        <div class="form-group">
            <label>سبب الرفض:</label>
            <textarea id="rejectReason" class="form-control" rows="3" required></textarea>
        </div>
        <div class="form-group">
            <label>ملاحظات:</label>
            <textarea id="rejectAdminNotes" class="form-control" rows="2"></textarea>
        </div>
        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button class="btn btn-secondary" onclick="closeRejectModal()">إلغاء</button>
            <button class="btn btn-danger" id="rejectBtn">تأكيد الرفض</button>
        </div>
    </div>
</div>

<script>
    let currentPaymentId = null;
    let currentUserEmail = null;
    let currentAmount = null;

    function confirmPaymentModal(paymentId, userEmail, amount) {
        currentPaymentId = paymentId;
        currentUserEmail = userEmail;
        currentAmount = amount;
        document.getElementById('confirmInfo').innerHTML = `المستخدم: ${userEmail}<br>المبلغ: ${amount} ريال`;
        document.getElementById('confirmModal').style.display = 'flex';
    }

    function rejectPaymentModal(paymentId, userEmail) {
        currentPaymentId = paymentId;
        currentUserEmail = userEmail;
        document.getElementById('rejectInfo').innerHTML = `المستخدم: ${userEmail}`;
        document.getElementById('rejectModal').style.display = 'flex';
    }

    function closeModal() {
        document.getElementById('confirmModal').style.display = 'none';
        currentPaymentId = null;
    }

    function closeRejectModal() {
        document.getElementById('rejectModal').style.display = 'none';
        currentPaymentId = null;
    }

    document.getElementById('confirmBtn')?.addEventListener('click', async () => {
        const planId = document.getElementById('planId').value;
        const adminNotes = document.getElementById('adminNotes').value;
        
        if (!planId) {
            alert('يرجى إدخال معرف الخطة');
            return;
        }
        
        try {
            await apiFetch(`/api/payments/admin/confirm/${currentPaymentId}`, {
                method: 'POST',
                body: JSON.stringify({ plan_id: parseInt(planId), admin_notes: adminNotes })
            });
            alert('تم تأكيد الدفع بنجاح');
            location.reload();
        } catch (error) {
            alert(error.message);
        }
    });

    document.getElementById('rejectBtn')?.addEventListener('click', async () => {
        const reason = document.getElementById('rejectReason').value;
        const adminNotes = document.getElementById('rejectAdminNotes').value;
        
        if (!reason) {
            alert('يرجى إدخال سبب الرفض');
            return;
        }
        
        try {
            await apiFetch(`/api/payments/admin/reject/${currentPaymentId}`, {
                method: 'POST',
                body: JSON.stringify({ reason, admin_notes: adminNotes })
            });
            alert('تم رفض الدفع');
            location.reload();
        } catch (error) {
            alert(error.message);
        }
    });

    async function refreshPending() {
        try {
            const data = await apiFetch('/api/payments/admin/requests?status=pending');
            location.reload();
        } catch (error) {
            alert('حدث خطأ في التحديث');
        }
    }
</script>