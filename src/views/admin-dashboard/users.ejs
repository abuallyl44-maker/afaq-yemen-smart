<div>
    <div class="card">
        <div class="card-header">
            <h3>👥 إدارة المستخدمين</h3>
            <div>
                <input type="text" id="searchInput" placeholder="بحث..." style="padding: 8px; border: 1px solid #ddd; border-radius: 5px;">
                <button class="btn btn-primary btn-sm" onclick="searchUsers()">بحث</button>
                <a href="/admin/users/export" class="btn btn-primary btn-sm">تصدير CSV</a>
            </div>
        </div>
        <div style="overflow-x: auto;">
            <table class="table">
                <thead>
                    <tr>
                        <th>#</th><th>البريد الإلكتروني</th><th>اسم المؤسسة</th><th>الاشتراك</th><th>تاريخ التسجيل</th><th>الحالة</th><th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody id="usersTable">
                    <% users.forEach(user => { %>
                    <tr>
                        <td><%= user.user_id %></td>
                        <td><%= user.email %></td>
                        <td><%= user.company_name || '-' %></td>
                        <td><%= user.current_subscription_id ? 'مشترك' : 'مجاني' %></td>
                        <td><%= new Date(user.created_at).toLocaleDateString('ar') %></td>
                        <td>
                            <span class="badge <%= user.status === 'active' ? 'badge-success' : 'badge-danger' %>">
                                <%= user.status === 'active' ? 'نشط' : 'موقوف' %>
                            </span>
                        </td>
                        <td>
                            <button class="btn btn-info btn-sm" onclick="viewUser(<%= user.user_id %>)">عرض</button>
                            <button class="btn btn-warning btn-sm" onclick="toggleUserStatus(<%= user.user_id %>, '<%= user.status %>')">
                                <%= user.status === 'active' ? 'تعليق' : 'تفعيل' %>
                            </button>
                            <button class="btn btn-danger btn-sm" onclick="deleteUser(<%= user.user_id %>)">حذف</button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    async function searchUsers() {
        const query = document.getElementById('searchInput').value;
        const result = await apiFetch(`/api/admin/users?search=${encodeURIComponent(query)}`);
        // تحديث الجدول
        location.reload();
    }
    
    async function viewUser(userId) {
        const user = await apiFetch(`/api/admin/users/${userId}`);
        alert(`المستخدم: ${user.email}\nالمؤسسة: ${user.company_name || '-'}\nالبوتات: ${user.whatsapp_bots?.length || 0}\nالمواقع: ${user.websites?.length || 0}`);
    }
    
    async function toggleUserStatus(userId, currentStatus) {
        const newStatus = currentStatus === 'active' ? 'suspended' : 'active';
        if (confirm(`هل أنت متأكد من ${newStatus === 'active' ? 'تفعيل' : 'تعليق'} هذا المستخدم؟`)) {
            await apiFetch(`/api/admin/users/${userId}/status`, {
                method: 'PUT',
                body: JSON.stringify({ status: newStatus })
            });
            location.reload();
        }
    }
    
    async function deleteUser(userId) {
        if (confirm('هل أنت متأكد من حذف هذا المستخدم؟ لا يمكن التراجع.')) {
            await apiFetch(`/api/admin/users/${userId}`, { method: 'DELETE' });
            location.reload();
        }
    }
</script>