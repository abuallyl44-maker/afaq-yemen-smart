<div>
    <!-- إحصائيات سريعة -->
    <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px;">
        <div class="stat-card">
            <div class="stat-info">
                <h3>تذاكر مفتوحة</h3>
                <div class="number" id="openCount"><%= openTickets?.length || 0 %></div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>قيد المعالجة</h3>
                <div class="number" id="progressCount"><%= inProgressTickets?.length || 0 %></div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>مغلقة</h3>
                <div class="number" id="closedCount"><%= closedTickets?.length || 0 %></div>
            </div>
        </div>
    </div>

    <!-- تبويبات -->
    <div class="card">
        <div class="card-header">
            <h3>📞 إدارة تذاكر الدعم</h3>
            <button class="btn btn-primary btn-sm" onclick="refreshTickets()">تحديث</button>
        </div>
        
        <div style="display: flex; border-bottom: 1px solid #eee; padding: 0 20px;">
            <button class="tab-btn active" data-tab="open" onclick="switchTab('open')">مفتوحة (<span id="openTabCount"><%= openTickets?.length || 0 %></span>)</button>
            <button class="tab-btn" data-tab="progress" onclick="switchTab('progress')">قيد المعالجة (<span id="progressTabCount"><%= inProgressTickets?.length || 0 %></span>)</button>
            <button class="tab-btn" data-tab="closed" onclick="switchTab('closed')">مغلقة (<span id="closedTabCount"><%= closedTickets?.length || 0 %></span>)</button>
        </div>

        <!-- التذاكر المفتوحة -->
        <div id="openTab" class="tab-content" style="padding: 20px;">
            <div style="overflow-x: auto;">
                <table class="table">
                    <thead>
                        <tr><th>#</th><th>المستخدم</th><th>الموضوع</th><th>النوع</th><th>التاريخ</th><th>الإجراءات</th></tr>
                    </thead>
                    <tbody>
                        <% if (openTickets && openTickets.length > 0) { %>
                            <% openTickets.forEach(ticket => { %>
                                <tr>
                                    <td><%= ticket.ticket_id %></td>
                                    <td><%= ticket.user?.email || '-' %></td>
                                    <td><%= ticket.subject %></td>
                                    <td><%= ticket.type %></td>
                                    <td><%= new Date(ticket.created_at).toLocaleDateString('ar') %></td>
                                    <td>
                                        <button class="btn btn-info btn-sm" onclick="viewTicket(<%= ticket.ticket_id %>)">عرض</button>
                                        <button class="btn btn-warning btn-sm" onclick="startProcessing(<%= ticket.ticket_id %>)">بدء المعالجة</button>
                                     </td>
                                 </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="6" style="text-align: center;">لا توجد تذاكر مفتوحة</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- التذاكر قيد المعالجة -->
        <div id="progressTab" class="tab-content" style="display: none; padding: 20px;">
            <div style="overflow-x: auto;">
                <table class="table">
                    <thead>
                        <tr><th>#</th><th>المستخدم</th><th>الموضوع</th><th>النوع</th><th>التاريخ</th><th>المعالج</th><th>الإجراءات</th></tr>
                    </thead>
                    <tbody>
                        <% if (inProgressTickets && inProgressTickets.length > 0) { %>
                            <% inProgressTickets.forEach(ticket => { %>
                                <tr>
                                    <td><%= ticket.ticket_id %></td>
                                    <td><%= ticket.user?.email || '-' %></td>
                                    <td><%= ticket.subject %></td>
                                    <td><%= ticket.type %></td>
                                    <td><%= new Date(ticket.created_at).toLocaleDateString('ar') %></td>
                                    <td><%= ticket.assigned_to || '-' %></td>
                                    <td>
                                        <button class="btn btn-info btn-sm" onclick="viewTicket(<%= ticket.ticket_id %>)">عرض</button>
                                        <button class="btn btn-success btn-sm" onclick="closeTicket(<%= ticket.ticket_id %>)">إغلاق</button>
                                     </td>
                                 </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="7" style="text-align: center;">لا توجد تذاكر قيد المعالجة</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- التذاكر المغلقة -->
        <div id="closedTab" class="tab-content" style="display: none; padding: 20px;">
            <div style="overflow-x: auto;">
                <table class="table">
                    <thead>
                        <tr><th>#</th><th>المستخدم</th><th>الموضوع</th><th>النوع</th><th>تاريخ الإغلاق</th><th>الإجراءات</th></tr>
                    </thead>
                    <tbody>
                        <% if (closedTickets && closedTickets.length > 0) { %>
                            <% closedTickets.forEach(ticket => { %>
                                <tr>
                                    <td><%= ticket.ticket_id %></td>
                                    <td><%= ticket.user?.email || '-' %></td>
                                    <td><%= ticket.subject %></td>
                                    <td><%= ticket.type %></td>
                                    <td><%= ticket.closed_at ? new Date(ticket.closed_at).toLocaleDateString('ar') : '-' %></td>
                                    <td><button class="btn btn-info btn-sm" onclick="viewTicket(<%= ticket.ticket_id %>)">عرض</button></td>
                                 </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="6" style="text-align: center;">لا توجد تذاكر مغلقة</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Modal عرض التذكرة والرد -->
<div id="ticketModal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; justify-content: center; align-items: center;">
    <div style="background: white; padding: 25px; border-radius: 10px; max-width: 600px; width: 90%; max-height: 80vh; overflow-y: auto;">
        <h3>تفاصيل التذكرة</h3>
        <div id="ticketDetails"></div>
        <div class="form-group">
            <label>الرد:</label>
            <textarea id="ticketReply" class="form-control" rows="5" placeholder="اكتب ردك هنا..."></textarea>
        </div>
        <div style="display: flex; gap: 10px; justify-content: flex-end;">
            <button class="btn btn-secondary" onclick="closeTicketModal()">إلغاء</button>
            <button class="btn btn-primary" id="sendReplyBtn">إرسال الرد</button>
        </div>
    </div>
</div>

<style>
    .tab-btn { padding: 10px 20px; background: none; border: none; cursor: pointer; font-size: 1rem; }
    .tab-btn.active { border-bottom: 2px solid #007bff; color: #007bff; }
</style>

<script>
    let currentTicketId = null;

    function switchTab(tab) {
        document.querySelectorAll('.tab-content').forEach(t => t.style.display = 'none');
        document.getElementById(`${tab}Tab`).style.display = 'block';
        document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
        document.querySelector(`.tab-btn[data-tab="${tab}"]`).classList.add('active');
    }

    async function viewTicket(ticketId) {
        currentTicketId = ticketId;
        const ticket = await apiFetch(`/api/admin/support/${ticketId}`);
        
        document.getElementById('ticketDetails').innerHTML = `
            <p><strong>رقم التذكرة:</strong> #${ticket.ticket_id}</p>
            <p><strong>المستخدم:</strong> ${ticket.user?.email || '-'}</p>
            <p><strong>الموضوع:</strong> ${ticket.subject}</p>
            <p><strong>النوع:</strong> ${ticket.type}</p>
            <p><strong>الرسالة:</strong></p>
            <div style="background: #f8f9fa; padding: 15px; border-radius: 5px; margin-bottom: 15px;">${ticket.message}</div>
            ${ticket.admin_reply ? `<p><strong>الرد السابق:</strong></p><div style="background: #e9ecef; padding: 15px; border-radius: 5px;">${ticket.admin_reply}</div>` : ''}
        `;
        
        document.getElementById('ticketModal').style.display = 'flex';
    }

    function closeTicketModal() {
        document.getElementById('ticketModal').style.display = 'none';
        currentTicketId = null;
        document.getElementById('ticketReply').value = '';
    }

    document.getElementById('sendReplyBtn')?.addEventListener('click', async () => {
        const reply = document.getElementById('ticketReply').value;
        if (!reply) {
            alert('يرجى كتابة الرد');
            return;
        }
        
        await apiFetch(`/api/admin/support/${currentTicketId}/reply`, {
            method: 'POST',
            body: JSON.stringify({ reply })
        });
        
        alert('تم إرسال الرد بنجاح');
        closeTicketModal();
        location.reload();
    });

    async function startProcessing(ticketId) {
        await apiFetch(`/api/admin/support/${ticketId}/start`, { method: 'POST' });
        location.reload();
    }

    async function closeTicket(ticketId) {
        if (confirm('هل أنت متأكد من إغلاق هذه التذكرة؟')) {
            await apiFetch(`/api/admin/support/${ticketId}/close`, { method: 'POST' });
            location.reload();
        }
    }

    async function refreshTickets() {
        location.reload();
    }
</script>