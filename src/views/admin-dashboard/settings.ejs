<div>
    <div class="card">
        <div class="card-header">
            <h3>⚙️ إعدادات النظام</h3>
        </div>
        <div style="padding: 20px;">
            <form id="settingsForm">
                <div class="form-group">
                    <label>الحد الأقصى للرسائل المجانية</label>
                    <input type="number" name="free_message_limit" class="form-control" value="<%= settings.free_message_limit %>">
                </div>
                <div class="form-group">
                    <label>الحد الأقصى للبوتات المجانية</label>
                    <input type="number" name="free_bot_limit" class="form-control" value="<%= settings.free_bot_limit %>">
                </div>
                <div class="form-group">
                    <label>فترة تجربة الموقع (أيام)</label>
                    <input type="number" name="website_trial_days" class="form-control" value="<%= settings.website_trial_days %>">
                </div>
                <div class="form-group">
                    <label>فترة انتظار تأكيد الدفع (ساعات)</label>
                    <input type="number" name="payment_waiting_hours" class="form-control" value="<%= settings.payment_waiting_hours %>">
                </div>
                <div class="form-group">
                    <label>معرف مجموعة تيليجرام للإشعارات</label>
                    <input type="text" name="admin_telegram_group_id" class="form-control" value="<%= settings.admin_telegram_group_id %>">
                </div>
                <div class="form-group">
                    <label>اسم الشركة</label>
                    <input type="text" name="company_name" class="form-control" value="<%= settings.company_name %>">
                </div>
                <div class="form-group">
                    <label>البريد الإلكتروني للشركة</label>
                    <input type="email" name="company_email" class="form-control" value="<%= settings.company_email %>">
                </div>
                <div class="form-group">
                    <label>رقم واتساب الشركة</label>
                    <input type="text" name="company_whatsapp" class="form-control" value="<%= settings.company_whatsapp %>">
                </div>
                <div class="form-group">
                    <label>Open Router API Key (للذكاء الاصطناعي)</label>
                    <input type="password" name="openrouter_api_key" class="form-control" value="<%= settings.openrouter_api_key %>">
                </div>
                <button type="submit" class="btn btn-primary">حفظ الإعدادات</button>
            </form>
        </div>
    </div>
</div>

<script>
    document.getElementById('settingsForm').addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        
        try {
            await apiFetch('/api/admin/settings', {
                method: 'PUT',
                body: JSON.stringify(data)
            });
            alert('تم حفظ الإعدادات بنجاح');
        } catch (error) {
            console.error(error);
        }
    });
</script>