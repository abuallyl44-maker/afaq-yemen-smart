<!-- Dashboard Content -->
<div>
    <!-- Stats Grid -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-info">
                <h3>إجمالي المستخدمين</h3>
                <div class="number"><%= stats.totalUsers %></div>
            </div>
            <div class="stat-icon">👥</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>المستخدمين النشطين</h3>
                <div class="number"><%= stats.activeUsers %></div>
            </div>
            <div class="stat-icon">✅</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>إجمالي البوتات</h3>
                <div class="number"><%= stats.totalBots %></div>
            </div>
            <div class="stat-icon">🤖</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>إجمالي المواقع</h3>
                <div class="number"><%= stats.totalWebsites %></div>
            </div>
            <div class="stat-icon">🌐</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>الإيرادات (هذا الشهر)</h3>
                <div class="number"><%= stats.monthlyRevenue %> ريال</div>
            </div>
            <div class="stat-icon">💰</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>تذاكر الدعم المفتوحة</h3>
                <div class="number"><%= stats.openTickets %></div>
            </div>
            <div class="stat-icon">🎫</div>
        </div>
    </div>

    <!-- Pending Payments -->
    <div class="card">
        <div class="card-header">
            <h3>⏳ طلبات الدفع المنتظرة (<%= pendingPayments.length %>)</h3>
            <a href="/admin/payments" class="btn btn-primary btn-sm">عرض الكل</a>
        </div>
        <div style="overflow-x: auto;">
            <table class="table">
                <thead>
                    <tr><th>المستخدم</th><th>المبلغ</th><th>الشركة</th><th>رقم الحوالة</th><th>التاريخ</th><th>الإجراءات</th></tr>
                </thead>
                <tbody>
                    <% pendingPayments.forEach(payment => { %>
                    <tr>
                        <td><%= payment.user?.email || 'N/A' %></td>
                        <td><%= payment.amount %> ريال</td>
                        <td><%= payment.company %></td>
                        <td><%= payment.transfer_number %></td>
                        <td><%= new Date(payment.requested_at).toLocaleDateString('ar') %></td>
                        <td>
                            <button class="btn btn-success btn-sm" onclick="confirmPayment(<%= payment.payment_id %>)">تأكيد</button>
                            <button class="btn btn-danger btn-sm" onclick="rejectPayment(<%= payment.payment_id %>)">رفض</button>
                        </td>
                    </tr>
                    <% }) %>
                    <% if (pendingPayments.length === 0) { %>
                    <tr><td colspan="6" style="text-align: center;">لا توجد طلبات منتظرة</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Users -->
    <div class="card">
        <div class="card-header">
            <h3>👤 آخر المستخدمين المسجلين</h3>
            <a href="/admin/users" class="btn btn-primary btn-sm">عرض الكل</a>
        </div>
        <div style="overflow-x: auto;">
            <table class="table">
                <thead><tr><th>البريد الإلكتروني</th><th>اسم المؤسسة</th><th>تاريخ التسجيل</th><th>الحالة</th></tr></thead>
                <tbody>
                    <% recentUsers.forEach(user => { %>
                    <tr>
                        <td><%= user.email %></td>
                        <td><%= user.company_name || '-' %></td>
                        <td><%= new Date(user.created_at).toLocaleDateString('ar') %></td>
                        <td><span class="badge <%= user.status === 'active' ? 'badge-success' : 'badge-danger' %>"><%= user.status === 'active' ? 'نشط' : 'موقوف' %></span></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    async function confirmPayment(paymentId) {
        if (confirm('هل أنت متأكد من تأكيد هذا الدفع؟')) {
            try {
                const planId = prompt('يرجى إدخال معرف الخطة (plan_id):');
                if (!planId) return;
                
                const result = await apiFetch(`/api/payments/admin/confirm/${paymentId}`, {
                    method: 'POST',
                    body: JSON.stringify({ plan_id: parseInt(planId) })
                });
                alert('تم تأكيد الدفع وتفعيل الاشتراك');
                location.reload();
            } catch (error) {
                console.error(error);
            }
        }
    }
    
    async function rejectPayment(paymentId) {
        const reason = prompt('يرجى إدخال سبب الرفض:');
        if (reason) {
            try {
                await apiFetch(`/api/payments/admin/reject/${paymentId}`, {
                    method: 'POST',
                    body: JSON.stringify({ reason })
                });
                alert('تم رفض الدفع');
                location.reload();
            } catch (error) {
                console.error(error);
            }
        }
    }
</script>