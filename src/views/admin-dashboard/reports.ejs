<div>
    <!-- عنوان الصفحة -->
    <div style="margin-bottom: 25px;">
        <h2>📊 التقارير والإحصائيات</h2>
        <p>نظرة شاملة على أداء النظام والمستخدمين</p>
    </div>

    <!-- فلترة التاريخ -->
    <div class="card" style="margin-bottom: 25px;">
        <div class="card-header">
            <h3>📅 اختر الفترة</h3>
        </div>
        <div style="padding: 20px; display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
            <div class="form-group" style="margin: 0;">
                <label>من تاريخ</label>
                <input type="date" id="dateFrom" class="form-control" value="<%= dateFrom %>">
            </div>
            <div class="form-group" style="margin: 0;">
                <label>إلى تاريخ</label>
                <input type="date" id="dateTo" class="form-control" value="<%= dateTo %>">
            </div>
            <button class="btn btn-primary" onclick="applyDateFilter()">تطبيق</button>
            <button class="btn btn-secondary" onclick="exportReport()">📥 تصدير التقرير</button>
        </div>
    </div>

    <!-- بطاقات الإحصائيات السريعة -->
    <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px; margin-bottom: 25px;">
        <div class="stat-card">
            <div class="stat-info">
                <h3>إجمالي المستخدمين</h3>
                <div class="number"><%= stats.totalUsers %></div>
            </div>
            <div class="stat-icon">👥</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>المستخدمين النشطين</h3>
                <div class="number"><%= stats.activeUsers %></div>
            </div>
            <div class="stat-icon">✅</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>المستخدمين الجدد (هذا الشهر)</h3>
                <div class="number"><%= stats.newUsersThisMonth %></div>
            </div>
            <div class="stat-icon">🆕</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>المستخدمين الذين دفعوا</h3>
                <div class="number"><%= stats.payingUsers %></div>
            </div>
            <div class="stat-icon">💰</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>المستخدمين الذين لم يدفعوا</h3>
                <div class="number"><%= stats.nonPayingUsers %></div>
            </div>
            <div class="stat-icon">🆓</div>
        </div>
        <div class="stat-card">
            <div class="stat-info">
                <h3>الإيرادات الإجمالية</h3>
                <div class="number"><%= stats.totalRevenue %> ريال</div>
            </div>
            <div class="stat-icon">💵</div>
        </div>
    </div>

    <!-- الرسم البياني: المستخدمين الجدد -->
    <div class="card" style="margin-bottom: 25px;">
        <div class="card-header">
            <h3>📈 المستخدمين الجدد (آخر 12 شهراً)</h3>
        </div>
        <div style="padding: 20px;">
            <canvas id="usersChart" style="max-height: 300px; width: 100%;"></canvas>
        </div>
    </div>

    <!-- الرسم البياني: الإيرادات الشهرية -->
    <div class="card" style="margin-bottom: 25px;">
        <div class="card-header">
            <h3>💰 الإيرادات الشهرية (بالريال)</h3>
        </div>
        <div style="padding: 20px;">
            <canvas id="revenueChart" style="max-height: 300px; width: 100%;"></canvas>
        </div>
    </div>

    <!-- الرسم البياني: توزيع المستخدمين حسب الخطة -->
    <div class="card" style="margin-bottom: 25px;">
        <div class="card-header">
            <h3>🥧 توزيع المستخدمين حسب خطة الاشتراك</h3>
        </div>
        <div style="padding: 20px; display: flex; flex-wrap: wrap; gap: 30px; justify-content: center;">
            <div style="flex: 1; min-width: 250px;">
                <canvas id="plansChart" style="max-height: 250px; width: 100%;"></canvas>
            </div>
            <div style="flex: 1; min-width: 200px;">
                <table class="table">
                    <thead>
                        <tr><th>الخطة</th><th>العدد</th><th>النسبة</th></tr>
                    </thead>
                    <tbody>
                        <% if (stats.planDistribution && stats.planDistribution.length > 0) { %>
                            <% stats.planDistribution.forEach(plan => { %>
                                <tr>
                                    <td><%= plan.name %></td>
                                    <td><%= plan.count %></td>
                                    <td><%= plan.percentage %>%</td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr><td colspan="3" style="text-align: center;">لا توجد بيانات</td></tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- جدول المستخدمين (من دفع ومن لم يدفع) -->
    <div class="card">
        <div class="card-header">
            <h3>📋 تفاصيل المستخدمين (من دفع ومن لم يدفع)</h3>
        </div>
        <div style="padding: 20px; overflow-x: auto;">
            <table class="table" id="usersTable">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>البريد الإلكتروني</th>
                        <th>اسم المؤسسة</th>
                        <th>الخطة</th>
                        <th>حالة الدفع</th>
                        <th>تاريخ التسجيل</th>
                        <th>آخر نشاط</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (users && users.length > 0) { %>
                        <% users.forEach(user => { %>
                            <tr>
                                <td><%= user.user_id %></td>
                                <td><%= user.email %></td>
                                <td><%= user.company_name || '-' %></td>
                                <td><%= user.plan_name || 'مجاني' %></td>
                                <td>
                                    <span class="badge <%= user.has_paid ? 'badge-success' : 'badge-warning' %>">
                                        <%= user.has_paid ? 'مدفوع' : 'غير مدفوع' %>
                                    </span>
                                </td>
                                <td><%= new Date(user.created_at).toLocaleDateString('ar') %></td>
                                <td><%= user.last_login ? new Date(user.last_login).toLocaleDateString('ar') : '-' %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="7" style="text-align: center;">لا توجد بيانات</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- إضافة مكتبة Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

<script>
    let usersChart, revenueChart, plansChart;

    // بيانات من الخادم
    const monthlyUsers = <%= JSON.stringify(monthlyUsers) %> || [];
    const monthlyRevenue = <%= JSON.stringify(monthlyRevenue) %> || [];
    const planDistribution = <%= JSON.stringify(stats.planDistribution) %> || [];

    // تهيئة الرسوم البيانية
    function initCharts() {
        // رسم بياني للمستخدمين الجدد
        const usersCtx = document.getElementById('usersChart').getContext('2d');
        usersChart = new Chart(usersCtx, {
            type: 'line',
            data: {
                labels: monthlyUsers.map(m => m.month),
                datasets: [{
                    label: 'عدد المستخدمين الجدد',
                    data: monthlyUsers.map(m => m.count),
                    borderColor: '#007bff',
                    backgroundColor: 'rgba(0, 123, 255, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'top' }
                }
            }
        });

        // رسم بياني للإيرادات
        const revenueCtx = document.getElementById('revenueChart').getContext('2d');
        revenueChart = new Chart(revenueCtx, {
            type: 'bar',
            data: {
                labels: monthlyRevenue.map(m => m.month),
                datasets: [{
                    label: 'الإيرادات (ريال)',
                    data: monthlyRevenue.map(m => m.amount),
                    backgroundColor: '#28a745',
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'top' }
                }
            }
        });

        // رسم بياني لتوزيع الخطط
        if (planDistribution.length > 0) {
            const plansCtx = document.getElementById('plansChart').getContext('2d');
            plansChart = new Chart(plansCtx, {
                type: 'pie',
                data: {
                    labels: planDistribution.map(p => p.name),
                    datasets: [{
                        data: planDistribution.map(p => p.count),
                        backgroundColor: ['#007bff', '#28a745', '#ffc107', '#dc3545', '#17a2b8'],
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }
    }

    // تطبيق فلترة التاريخ
    async function applyDateFilter() {
        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;
        
        window.location.href = `/admin/reports?from=${dateFrom}&to=${dateTo}`;
    }

    // تصدير التقرير
    async function exportReport() {
        const dateFrom = document.getElementById('dateFrom').value;
        const dateTo = document.getElementById('dateTo').value;
        
        window.location.href = `/api/admin/reports/export?from=${dateFrom}&to=${dateTo}`;
    }

    // إضافة بحث للجدول
    function addTableSearch() {
        const searchInput = document.createElement('input');
        searchInput.type = 'text';
        searchInput.placeholder = 'بحث...';
        searchInput.className = 'form-control';
        searchInput.style.width = '250px';
        searchInput.style.marginBottom = '15px';
        
        const cardHeader = document.querySelector('#usersTable').closest('.card')?.querySelector('.card-header');
        if (cardHeader) {
            cardHeader.appendChild(searchInput);
            
            searchInput.addEventListener('keyup', function() {
                const searchTerm = this.value.toLowerCase();
                const rows = document.querySelectorAll('#usersTable tbody tr');
                
                rows.forEach(row => {
                    const text = row.textContent.toLowerCase();
                    row.style.display = text.includes(searchTerm) ? '' : 'none';
                });
            });
        }
    }

    // تهيئة الصفحة
    document.addEventListener('DOMContentLoaded', () => {
        initCharts();
        addTableSearch();
    });
</script>

<style>
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 15px;
    }
    .stat-card {
        background: white;
        border-radius: 10px;
        padding: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0 2px 5px rgba(0,0,0,0.05);
    }
    .stat-info h3 {
        font-size: 0.85rem;
        color: #666;
        margin-bottom: 5px;
    }
    .stat-info .number {
        font-size: 1.75rem;
        font-weight: bold;
        color: #007bff;
    }
    .stat-icon {
        font-size: 2rem;
        opacity: 0.3;
    }
    .badge-success {
        background-color: #28a745;
        color: white;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
    }
    .badge-warning {
        background-color: #ffc107;
        color: #333;
        padding: 5px 10px;
        border-radius: 20px;
        font-size: 0.75rem;
    }
</style>